# PostgreSQL (local Docker defaults; Azure: set to Flexible Server connection string)
DATABASE_URL="postgresql://quri:quri@localhost:5432/quri?schema=public"

# API
PORT=3000

# Auth (JWT) — 운영에서는 반드시 강력한 무작위 시크릿으로 교체하세요.
JWT_SECRET="dev-insecure-secret-change-me"
JWT_EXPIRES_IN="7d"

# Copilot CLI
# Path/name of the copilot binary (must be on PATH at runtime)
COPILOT_BIN=copilot
# Model to use for generation (auto lets Copilot choose)
COPILOT_MODEL=auto
# Timeout (ms) for a single generation call
COPILOT_TIMEOUT_MS=120000

# 메일(SMTP) — 회원가입 이메일 인증 코드 발송용. Gmail 은 앱 비밀번호를 사용하세요.
# (계정 → 보안 → 2단계 인증 → 앱 비밀번호). 비워두면 코드가 서버 로그로만 출력됩니다.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-account@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM="Quri <your-account@gmail.com>"

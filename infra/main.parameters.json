{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "namePrefix": {
      "value": "${NAME_PREFIX=lipcode}"
    },
    "dbAdminUser": {
      "value": "${DB_ADMIN_USER=lipcode}"
    },
    "dbAdminPassword": {
      "value": "${DB_ADMIN_PASSWORD}"
    },
    "jwtSecret": {
      "value": "${JWT_SECRET}"
    },
    "mailHost": {
      "value": "${MAIL_HOST=smtp.gmail.com}"
    },
    "mailPort": {
      "value": "${MAIL_PORT=587}"
    },
    "mailUsername": {
      "value": "${MAIL_USERNAME=}"
    },
    "mailPassword": {
      "value": "${MAIL_PASSWORD=}"
    },
    "mailFrom": {
      "value": "${MAIL_FROM=}"
    },
    "copilotGithubToken": {
      "value": "${COPILOT_GITHUB_TOKEN=}"
    }
  }
}
